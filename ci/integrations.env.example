# Example environment variables for external integrations
# Copy this file to `ci/.env` (or to your local `.env`) and fill values.

# Mail / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=noreply@example.com

# SendGrid / Mail providers
SENDGRID_API_KEY=
MAILGUN_API_KEY=

# OAuth / OIDC (Google, GitHub examples)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=

# SMS / Messaging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Webhooks / notifications
SLACK_WEBHOOK_URL=

# Cloud storage / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=

# General
ALLOWED_HOSTS=localhost

# NOTE: Keep real secret values out of version control. Use CI secret stores
# or generate ephemeral values in CI runs and keep local `.env` files ignored.
