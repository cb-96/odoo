<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view -->
    <record id="view_federation_club_representative_form" model="ir.ui.view">
        <field name="name">federation.club.representative.form</field>
        <field name="model">federation.club.representative</field>
        <field name="arch" type="xml">
            <form string="Club Representative">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_partner"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-user"
                                string="Contact"/>
                        <button name="action_view_user"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users"
                                invisible="not user_id"
                                string="User"/>
                    </div>
                    <div class="oe_title">
                        <label for="display_name"/>
                        <h1>
                            <field name="display_name" placeholder="Representative Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Club and Contact">
                            <field name="club_id"/>
                            <field name="representative_ids"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Role">
                            <field name="role_type_id"/>
                            <field name="is_primary"/>
                            <field name="is_current"/>
                        </group>
                    </group>
                    <group>
                        <group string="Tenure">
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group string="Status">
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List view -->
    <record id="view_federation_club_representative_list" model="ir.ui.view">
        <field name="name">federation.club.representative.list</field>
        <field name="model">federation.club.representative</field>
        <field name="arch" type="xml">
            <list string="Club Representatives">
                <field name="club_id"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="role_type_id"/>
                <field name="is_primary"/>
                <field name="is_current"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_federation_club_representative_search" model="ir.ui.view">
        <field name="name">federation.club.representative.search</field>
        <field name="model">federation.club.representative</field>
        <field name="arch" type="xml">
            <search string="Search Club Representatives">
                <field name="club_id"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="role_type_id"/>
                <filter name="primary" string="Primary Contacts" domain="[('is_primary', '=', True)]"/>
                <filter name="current" string="Currently Active" domain="[('is_current', '=', True)]"/>

                <separator/>
                <group>
                    <filter name="club" string="Club" context="{'group_by': 'club_id'}"/>
                    <filter name="role_type" string="Role Type" context="{'group_by': 'role_type_id'}"/>
                    <filter name="partner" string="Contact" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_federation_club_representative" model="ir.actions.act_window">
        <field name="name">Club Representatives</field>
        <field name="res_model">federation.club.representative</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_club_representative_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add representatives to clubs.
            </p>
            <p>
                Representatives are the people who act on behalf of a club in the federation.
            </p>
        </field>
    </record>

</odoo>