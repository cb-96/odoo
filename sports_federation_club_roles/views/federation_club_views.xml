<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend club form with representatives tab -->
    <record id="view_federation_club_form_representatives" model="ir.ui.view">
        <field name="name">federation.club.form.representatives</field>
        <field name="model">federation.club</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_club_form"/>
        <field name="arch" type="xml">
            <!-- Add representatives stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_representatives"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-users">
                    <field name="representative_count" widget="statinfo" string="Representatives"/>
                </button>
                <button name="action_view_primary_contacts"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-star">
                    <field name="primary_contact_count" widget="statinfo" string="Primary"/>
                </button>
                <button name="action_view_competition_contacts"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-trophy"
                        context="{'search_default_competition': 1}">
                    <field name="competition_contact_count" widget="statinfo" string="Competition"/>
                </button>
                <button name="action_view_finance_contacts"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money"
                        context="{'search_default_finance': 1}">
                    <field name="finance_contact_count" widget="statinfo" string="Finance"/>
                </button>
                <button name="action_view_safeguarding_contacts"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shield"
                        context="{'search_default_safeguarding': 1}">
                    <field name="safeguarding_contact_count" widget="statinfo" string="Safeguarding"/>
                </button>
            </xpath>

            <!-- Add representatives list before notes -->
            <xpath expr="//field[@name='notes']" position="before">
                <field name="representative_ids">
                    <list editable="bottom">
                        <field name="partner_id"/>
                        <field name="user_id"/>
                        <field name="role_type_id"/>
                        <field name="is_primary"/>
                        <field name="is_current"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="active" widget="boolean_toggle"/>
                    </list>
                </field>
            </xpath>
        </field>
    </record>

</odoo>