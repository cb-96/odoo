<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tournament_template_form" model="ir.ui.view">
        <field name="name">federation.tournament.template.form</field>
        <field name="model">federation.tournament.template</field>
        <field name="arch" type="xml">
            <form string="Tournament Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Template Name"/></h1>
                    </div>
                    <field name="description" placeholder="Description..."/>
                    <notebook>
                        <page string="Stages">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="stage_name"/>
                                    <field name="stage_type"/>
                                    <field name="format"/>
                                    <field name="group_count"/>
                                    <field name="teams_per_group"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Progression Rules">
                            <field name="progression_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="source_line_id"/>
                                    <field name="target_line_id"/>
                                    <field name="rank_from"/>
                                    <field name="rank_to"/>
                                    <field name="seeding_method"/>
                                    <field name="auto_advance"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tournament_template_tree" model="ir.ui.view">
        <field name="name">federation.tournament.template.tree</field>
        <field name="model">federation.tournament.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="action_tournament_template" model="ir.actions.act_window">
        <field name="name">Tournament Templates</field>
        <field name="res_model">federation.tournament.template</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
