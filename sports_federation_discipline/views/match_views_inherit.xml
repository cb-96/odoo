<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_federation_match_form_inherit_discipline" model="ir.ui.view">
        <field name="name">federation.match.form.inherit.discipline</field>
        <field name="model">federation.match</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_match_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_view_incidents" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
                    <field name="incident_count" string="Incidents" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Incidents" name="incidents">
                    <field name="incident_ids">
                        <list>
                            <field name="name"/>
                            <field name="incident_type"/>
                            <field name="player_id"/>
                            <field name="club_id"/>
                            <field name="referee_id"/>
                            <field name="minute_text"/>
                            <field name="status"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>