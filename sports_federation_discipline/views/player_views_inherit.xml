<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_federation_player_form_inherit_discipline" model="ir.ui.view">
        <field name="name">federation.player.form.inherit.discipline</field>
        <field name="model">federation.player</field>
        <field name="inherit_id" ref="sports_federation_people.view_federation_player_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_view_suspensions" type="object" class="oe_stat_button" icon="fa-ban">
                    <field name="suspension_count" string="Suspensions" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Suspensions" name="suspensions">
                    <field name="suspension_ids">
                        <list>
                            <field name="name"/>
                            <field name="case_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="state"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>