<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_federation_audit_note_form" model="ir.ui.view">
        <field name="name">federation.audit.note.form</field>
        <field name="model">federation.audit.note</field>
        <field name="arch" type="xml">
            <form string="Audit Note">
                <group>
                    <group>
                        <field name="request_id"/>
                        <field name="author_id"/>
                        <field name="created_on"/>
                    </group>
                </group>
                <group string="Note">
                    <field name="note" nolabel="1"/>
                </group>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_federation_audit_note_tree" model="ir.ui.view">
        <field name="name">federation.audit.note.tree</field>
        <field name="model">federation.audit.note</field>
        <field name="arch" type="xml">
            <list string="Audit Notes">
                <field name="request_id"/>
                <field name="author_id"/>
                <field name="created_on"/>
                <field name="note"/>
            </list>
        </field>
    </record>

</odoo>