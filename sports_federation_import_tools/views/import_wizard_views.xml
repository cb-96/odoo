<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Import Clubs Wizard Form -->
    <record id="view_federation_import_clubs_wizard_form" model="ir.ui.view">
        <field name="name">federation.import.clubs.wizard.form</field>
        <field name="model">federation.import.clubs.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Clubs">
                <group>
                    <group>
                        <field name="upload_file" filename="upload_filename"/>
                        <field name="upload_filename" invisible="1"/>
                        <field name="dry_run"/>
                    </group>
                    <group invisible="line_count = 0">
                        <field name="line_count"/>
                        <field name="success_count"/>
                        <field name="error_count"/>
                    </group>
                </group>
                <group invisible="result_message = False">
                    <field name="result_message" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_parse_and_import" string="Parse &amp; Import" type="object" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

