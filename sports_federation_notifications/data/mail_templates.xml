<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Generic Contact Template -->
    <record id="template_federation_generic_contact" model="mail.template">
        <field name="name">Federation: Generic Contact</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="subject">Message from Sports Federation</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.name"/>,</p>
            <p>This is a message from the Sports Federation.</p>
            <p><t t-out="ctx.get('message_body', '')"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <!-- Registration Reminder Template -->
    <record id="template_federation_registration_reminder" model="mail.template">
        <field name="name">Federation: Registration Reminder</field>
        <field name="model_id" ref="sports_federation_base.model_federation_season_registration"/>
        <field name="subject">Reminder: Complete Your Season Registration</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.club_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.club_id.name"/>,</p>
            <p>This is a reminder that your season registration <strong><t t-out="object.name"/></strong> is still in draft status.</p>
            <p>Please complete your registration as soon as possible.</p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_season_registration_confirmed" model="mail.template">
        <field name="name">Federation: Season Registration Confirmed</field>
        <field name="model_id" ref="sports_federation_base.model_federation_season_registration"/>
        <field name="subject">Season Registration Confirmed: <t t-out="object.name"/></field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.partner_id.email or object.club_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.partner_id.name or object.club_id.name"/>,</p>
            <p>Your season registration <strong><t t-out="object.name"/></strong> has been confirmed.</p>
            <p>Team: <t t-out="object.team_id.name"/></p>
            <p>Season: <t t-out="object.season_id.name"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_season_registration_rejected" model="mail.template">
        <field name="name">Federation: Season Registration Requires Update</field>
        <field name="model_id" ref="sports_federation_base.model_federation_season_registration"/>
        <field name="subject">Season Registration Returned to Draft: <t t-out="object.name"/></field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.partner_id.email or object.club_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.partner_id.name or object.club_id.name"/>,</p>
            <p>Your season registration <strong><t t-out="object.name"/></strong> has been returned to draft for updates.</p>
            <p t-if="object.rejection_reason">Reason: <t t-out="object.rejection_reason"/></p>
            <p>You can update the registration from the portal and submit it again.</p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <!-- Missing Data Notice Template -->
    <record id="template_federation_missing_data_notice" model="mail.template">
        <field name="name">Federation: Missing Data Notice</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="subject">Action Required: Missing Information</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.name"/>,</p>
            <p>We have noticed that some required information is missing from your federation profile.</p>
            <p>Please update your profile to ensure we have all necessary details.</p>
            <p><t t-out="ctx.get('missing_items', '')"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

</odoo>