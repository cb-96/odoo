<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Generic Contact Template -->
    <record id="template_federation_generic_contact" model="mail.template">
        <field name="name">Federation: Generic Contact</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="subject">Message from Sports Federation</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.name"/>,</p>
            <p>This is a message from the Sports Federation.</p>
            <p><t t-out="ctx.get('message_body', '')"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <!-- Registration Reminder Template -->
    <record id="template_federation_registration_reminder" model="mail.template">
        <field name="name">Federation: Registration Reminder</field>
        <field name="model_id" ref="sports_federation_base.model_federation_season_registration"/>
        <field name="subject">Reminder: Complete Your Season Registration</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.club_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.club_id.name"/>,</p>
            <p>This is a reminder that your season registration <strong><t t-out="object.name"/></strong> is still in draft status.</p>
            <p>Please complete your registration as soon as possible.</p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_season_registration_confirmed" model="mail.template">
        <field name="name">Federation: Season Registration Confirmed</field>
        <field name="model_id" ref="sports_federation_base.model_federation_season_registration"/>
        <field name="subject">Season Registration Confirmed: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.partner_id.email or object.club_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.partner_id.name or object.club_id.name"/>,</p>
            <p>Your season registration <strong><t t-out="object.name"/></strong> has been confirmed.</p>
            <p>Team: <t t-out="object.team_id.name"/></p>
            <p>Season: <t t-out="object.season_id.name"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_season_registration_rejected" model="mail.template">
        <field name="name">Federation: Season Registration Requires Update</field>
        <field name="model_id" ref="sports_federation_base.model_federation_season_registration"/>
        <field name="subject">Season Registration Returned to Draft: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.partner_id.email or object.club_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.partner_id.name or object.club_id.name"/>,</p>
            <p>Your season registration <strong><t t-out="object.name"/></strong> has been returned to draft for updates.</p>
            <p t-if="object.rejection_reason">Reason: <t t-out="object.rejection_reason"/></p>
            <p>You can update the registration from the portal and submit it again.</p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_tournament_published" model="mail.template">
        <field name="name">Federation: Tournament Published</field>
        <field name="model_id" ref="sports_federation_tournament.model_federation_tournament"/>
        <field name="subject">Tournament Published: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ '' }}</field>
        <field name="body_html" type="html">
            <p>Dear club contact,</p>
            <p>The tournament <strong><t t-out="object.name"/></strong> is now published.</p>
            <p t-if="object.season_id">Season: <t t-out="object.season_id.name"/></p>
            <div t-if="object.public_description">
                <p>Public description:</p>
                <div><t t-out="object.public_description"/></div>
            </div>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_participant_confirmed" model="mail.template">
        <field name="name">Federation: Participant Confirmed</field>
        <field name="model_id" ref="sports_federation_tournament.model_federation_tournament_participant"/>
        <field name="subject">Tournament Participation Confirmed: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.team_id.email or object.club_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.club_id.name or object.team_id.name"/>,</p>
            <p>Your participant entry <strong><t t-out="object.name"/></strong> has been confirmed.</p>
            <p>Tournament: <t t-out="object.tournament_id.name"/></p>
            <p>Team: <t t-out="object.team_id.name"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_result_approved" model="mail.template">
        <field name="name">Federation: Result Approved</field>
        <field name="model_id" ref="sports_federation_tournament.model_federation_match"/>
        <field name="subject">Official Result Approved: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.home_team_id.club_id.email or object.home_team_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear club contact,</p>
            <p>The match result for <strong><t t-out="object.name"/></strong> has been approved.</p>
            <p>Score: <t t-out="object.home_team_id.name"/> <t t-out="object.home_score"/> - <t t-out="object.away_score"/> <t t-out="object.away_team_id.name"/></p>
            <p>The result is now included in the official standings.</p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_result_contested" model="mail.template">
        <field name="name">Federation: Result Contested</field>
        <field name="model_id" ref="sports_federation_tournament.model_federation_match"/>
        <field name="subject">Result Contested: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.home_team_id.club_id.email or object.home_team_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear club contact,</p>
            <p>The result for <strong><t t-out="object.name"/></strong> has been contested.</p>
            <p t-if="object.result_contest_reason">Reason: <t t-out="object.result_contest_reason"/></p>
            <p>The result is removed from official standings until the dispute is resolved.</p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_standing_frozen" model="mail.template">
        <field name="name">Federation: Standing Frozen</field>
        <field name="model_id" ref="sports_federation_standings.model_federation_standing"/>
        <field name="subject">Standings Frozen: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ '' }}</field>
        <field name="body_html" type="html">
            <p>Dear tournament participant,</p>
            <p>The standing <strong><t t-out="object.name"/></strong> has been frozen.</p>
            <p>Tournament: <t t-out="object.tournament_id.name"/></p>
            <p>This standing is now treated as an official snapshot.</p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_finance_confirmed" model="mail.template">
        <field name="name">Federation: Finance Event Confirmed</field>
        <field name="model_id" ref="sports_federation_finance_bridge.model_federation_finance_event"/>
        <field name="subject">Finance Event Confirmed: {{ object.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.partner_id.email or object.club_id.email or object.player_id.email or object.referee_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear federation contact,</p>
            <p>The finance event <strong><t t-out="object.name"/></strong> has been confirmed.</p>
            <p>Amount: <t t-out="object.amount"/> <t t-out="object.currency_id.name"/></p>
            <p>Reference: <t t-out="object.external_ref or object.invoice_ref or 'Pending reference'"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <record id="template_federation_referee_assigned" model="mail.template">
        <field name="name">Federation: Referee Assigned</field>
        <field name="model_id" ref="sports_federation_officiating.model_federation_match_referee"/>
        <field name="subject">Match Assignment: {{ object.match_id.name }}</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.referee_id.email or '' }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.referee_id.name"/>,</p>
            <p>You have been assigned to <strong><t t-out="object.match_id.name"/></strong>.</p>
            <p>Role: <t t-out="object.role"/></p>
            <p t-if="object.tournament_id">Tournament: <t t-out="object.tournament_id.name"/></p>
            <p t-if="object.confirmation_deadline">Confirmation deadline: <t t-out="object.confirmation_deadline"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

    <!-- Missing Data Notice Template -->
    <record id="template_federation_missing_data_notice" model="mail.template">
        <field name="name">Federation: Missing Data Notice</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="subject">Action Required: Missing Information</field>
        <field name="email_from">{{ (user.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="body_html" type="html">
            <p>Dear <t t-out="object.name"/>,</p>
            <p>We have noticed that some required information is missing from your federation profile.</p>
            <p>Please update your profile to ensure we have all necessary details.</p>
            <p><t t-out="ctx.get('missing_items', '')"/></p>
            <p>Best regards,<br/>Sports Federation</p>
        </field>
    </record>

</odoo>