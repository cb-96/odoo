<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree view -->
    <record id="view_federation_club_representative_tree" model="ir.ui.view">
        <field name="name">federation.club.representative.tree</field>
        <field name="model">federation.club.representative</field>
        <field name="arch" type="xml">
            <tree>
                <field name="club_id"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="role"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_federation_club_representative_form" model="ir.ui.view">
        <field name="name">federation.club.representative.form</field>
        <field name="model">federation.club.representative</field>
        <field name="arch" type="xml">
            <form string="Club Representative">
                <sheet>
                    <group>
                        <group>
                            <field name="club_id"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="role"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_federation_club_representative" model="ir.actions.act_window">
        <field name="name">Club Representatives</field>
        <field name="res_model">federation.club.representative</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>