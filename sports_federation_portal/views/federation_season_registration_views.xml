<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_season_registration_portal_list" model="ir.ui.view">
        <field name="name">federation.season.registration.portal.list</field>
        <field name="model">federation.season.registration</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_season_registration_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-warning">state == 'submitted'</attribute>
                <attribute name="decoration-success">state == 'confirmed'</attribute>
                <attribute name="decoration-muted">state == 'cancelled'</attribute>
            </xpath>
            <xpath expr="//field[@name='registration_date']" position="before">
                <field name="user_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_federation_season_registration_portal_form" model="ir.ui.view">
        <field name="name">federation.season.registration.portal.form</field>
        <field name="model">federation.season.registration</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_season_registration_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header/button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">state not in ('draft', 'submitted')</attribute>
            </xpath>
            <xpath expr="//form/header" position="inside">
                <button name="action_submit" string="Submit" type="object"
                        class="btn-primary" invisible="state != 'draft'"/>
                <button name="action_reject" string="Reject" type="object"
                        class="btn-danger" invisible="state != 'submitted'"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,submitted,confirmed,cancelled</attribute>
            </xpath>
            <xpath expr="//group[@string='Details']" position="inside">
                <field name="user_id" readonly="1"/>
                <field name="partner_id" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='notes']" position="before">
                <field name="rejection_reason" readonly="1" invisible="not rejection_reason"/>
            </xpath>
        </field>
    </record>

    <record id="view_federation_season_registration_portal_search" model="ir.ui.view">
        <field name="name">federation.season.registration.portal.search</field>
        <field name="model">federation.season.registration</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_season_registration_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='draft']" position="after">
                <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
            </xpath>
        </field>
    </record>

</odoo>