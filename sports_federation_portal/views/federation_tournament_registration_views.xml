<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree view -->
    <record id="view_federation_tournament_registration_tree" model="ir.ui.view">
        <field name="name">federation.tournament.registration.tree</field>
        <field name="model">federation.tournament.registration</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="tournament_id"/>
                <field name="team_id"/>
                <field name="club_id"/>
                <field name="user_id"/>
                <field name="registration_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_federation_tournament_registration_form" model="ir.ui.view">
        <field name="name">federation.tournament.registration.form</field>
        <field name="model">federation.tournament.registration</field>
        <field name="arch" type="xml">
            <form string="Tournament Registration">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-success"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject" type="object"
                            class="btn-danger"
                            invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            class="btn-warning"
                            invisible="state in ('confirmed', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(sports_federation_tournament.action_federation_tournament_participant)d"
                                type="action" class="oe_stat_button"
                                icon="fa-users"
                                invisible="not participant_id">
                            <field name="participant_id" string="Participant" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tournament_id"/>
                            <field name="team_id"/>
                            <field name="club_id"/>
                            <field name="season_id"/>
                        </group>
                        <group>
                            <field name="registration_date"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                            <field name="participant_id"
                                   invisible="not participant_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                        <field name="rejection_reason"
                               invisible="state != 'rejected'"/>
                    </group>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_federation_tournament_registration_search" model="ir.ui.view">
        <field name="name">federation.tournament.registration.search</field>
        <field name="model">federation.tournament.registration</field>
        <field name="arch" type="xml">
            <search string="Tournament Registrations">
                <field name="name"/>
                <field name="tournament_id"/>
                <field name="team_id"/>
                <field name="club_id"/>
                <field name="user_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_rejected" string="Rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_tournament" string="Tournament" context="{'group_by': 'tournament_id'}"/>
                    <filter name="group_club" string="Club" context="{'group_by': 'club_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_federation_tournament_registration" model="ir.actions.act_window">
        <field name="name">Tournament Registrations</field>
        <field name="res_model">federation.tournament.registration</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_federation_tournament_registration_search"/>
    </record>

</odoo>