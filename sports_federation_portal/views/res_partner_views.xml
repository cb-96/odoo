<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend partner form with representative roles -->
    <record id="view_res_partner_form_representatives" model="ir.ui.view">
        <field name="name">res.partner.form.representatives</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Add representative roles stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_federation_representatives"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shield"
                        invisible="not federation_representative_count">
                    <field name="federation_representative_count" widget="statinfo" string="Club Roles"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>