<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Website menu: Tournaments -->
    <record id="menu_website_tournaments" model="website.menu">
        <field name="name">Tournaments</field>
        <field name="url">/tournaments</field>
        <field name="sequence" eval="50"/>
    </record>

    <!-- Backend menu for portal module -->
    <menuitem id="menu_federation_portal_root"
              name="Portal"
              parent="sports_federation_base.menu_federation_root"
              sequence="50"/>

    <menuitem id="menu_federation_tournament_registration"
              name="Tournament Registrations"
              parent="menu_federation_portal_root"
              action="action_federation_tournament_registration"
              sequence="10"/>

    <menuitem id="menu_federation_club_representative_portal"
              name="Club Representatives"
              parent="menu_federation_portal_root"
              action="action_federation_club_representative_portal"
              sequence="20"/>

</odoo>