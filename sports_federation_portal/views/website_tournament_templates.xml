<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Tournament List Page (Public)                                 -->
    <!-- ============================================================ -->

    <template id="tournament_list_page" name="Tournaments">
        <t t-call="website.layout">
            <div id="wrap" class="oe_website_sale">
                <div class="container py-4">
                    <div class="row mb-4">
                        <div class="col">
                            <h1>Tournaments</h1>
                            <p class="text-muted">Browse upcoming and current tournaments</p>
                        </div>
                    </div>

                    <!-- Search -->
                    <form action="/tournaments" method="GET" class="row mb-4">
                        <div class="col-md-8">
                            <div class="input-group">
                                <input type="text" name="search" class="form-control"
                                       placeholder="Search tournaments..."
                                       t-att-value="search"/>
                                <button class="btn btn-primary" type="submit">Search</button>
                            </div>
                        </div>
                    </form>

                    <!-- Tournament Cards -->
                    <div class="row">
                        <t t-foreach="tournaments" t-as="tournament">
                            <div class="col-md-4 mb-4">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <a t-attf-href="/tournament/#{tournament.id}">
                                                <t t-esc="tournament.name"/>
                                            </a>
                                        </h5>
                                        <div class="mb-2">
                                            <t t-if="tournament.date_start">
                                                <i class="fa fa-calendar me-1"/>
                                                <t t-esc="tournament.date_start"
                                                   t-options='{"widget": "date"}'/>
                                                <t t-if="tournament.date_end">
                                                    - <t t-esc="tournament.date_end"
                                                         t-options='{"widget": "date"}'/>
                                                </t>
                                            </t>
                                        </div>
                                        <div class="mb-2" t-if="tournament.location">
                                            <i class="fa fa-map-marker me-1"/>
                                            <t t-esc="tournament.location"/>
                                        </div>
                                        <div class="mb-2">
                                            <span class="badge"
                                                  t-att-class="'bg-success' if tournament.state == 'open' else 'bg-primary' if tournament.state == 'in_progress' else 'bg-secondary'">
                                                <t t-esc="dict(tournament._fields['state'].selection).get(tournament.state)"/>
                                            </span>
                                        </div>
                                        <div class="text-muted small" t-if="tournament.max_participants > 0">
                                            <t t-esc="tournament.participant_count"/> / <t t-esc="tournament.max_participants"/> participants
                                        </div>
                                    </div>
                                    <div class="card-footer">
                                        <a t-attf-href="/tournament/#{tournament.id}"
                                           class="btn btn-sm btn-outline-primary">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>

                    <div t-if="not tournaments" class="row">
                        <div class="col text-center py-5">
                            <p class="text-muted">No tournaments found.</p>
                        </div>
                    </div>

                    <!-- Pagination -->
                    <t t-call="website.pager" t-if="pager">
                        <t t-set="pager" t-value="pager"/>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Tournament Detail Page (Public)                               -->
    <!-- ============================================================ -->

    <template id="tournament_detail_page" name="Tournament Details">
        <t t-call="website.layout">
            <div id="wrap" class="oe_website_sale">
                <div class="container py-4">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/tournaments">Tournaments</a></li>
                            <li class="breadcrumb-item active">
                                <t t-esc="tournament.name"/>
                            </li>
                        </ol>
                    </nav>

                    <div class="row">
                        <div class="col-md-8">
                            <h1><t t-esc="tournament.name"/></h1>

                            <table class="table table-sm mt-4">
                                <tr>
                                    <th style="width:150px">Status</th>
                                    <td>
                                        <span class="badge"
                                              t-att-class="'bg-success' if tournament.state == 'open' else 'bg-primary' if tournament.state == 'in_progress' else 'bg-secondary' if tournament.state == 'closed' else 'bg-warning'">
                                            <t t-esc="dict(tournament._fields['state'].selection).get(tournament.state)"/>
                                        </span>
                                    </td>
                                </tr>
                                <tr t-if="tournament.date_start">
                                    <th>Start Date</th>
                                    <td><t t-esc="tournament.date_start" t-options='{"widget": "date"}'/></td>
                                </tr>
                                <tr t-if="tournament.date_end">
                                    <th>End Date</th>
                                    <td><t t-esc="tournament.date_end" t-options='{"widget": "date"}'/></td>
                                </tr>
                                <tr t-if="tournament.location">
                                    <th>Location</th>
                                    <td><t t-esc="tournament.location"/></td>
                                </tr>
                                <tr t-if="tournament.season_id">
                                    <th>Season</th>
                                    <td><t t-esc="tournament.season_id.name"/></td>
                                </tr>
                                <tr t-if="tournament.category">
                                    <th>Category</th>
                                    <td><t t-esc="dict(tournament._fields['category'].selection).get(tournament.category)"/></td>
                                </tr>
                                <tr t-if="tournament.gender">
                                    <th>Gender</th>
                                    <td><t t-esc="dict(tournament._fields['gender'].selection).get(tournament.gender)"/></td>
                                </tr>
                                <tr>
                                    <th>Type</th>
                                    <td><t t-esc="dict(tournament._fields['tournament_type'].selection).get(tournament.tournament_type)"/></td>
                                </tr>
                                <tr t-if="tournament.max_participants > 0">
                                    <th>Participants</th>
                                    <td><t t-esc="tournament.participant_count"/> / <t t-esc="tournament.max_participants"/></td>
                                </tr>
                            </table>

                            <div t-if="tournament.notes" class="mt-3">
                                <h5>Notes</h5>
                                <div class="text-muted"><t t-esc="tournament.notes"/></div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Actions</h5>
                                    <t t-if="can_register">
                                        <a t-attf-href="/tournament/#{tournament.id}/register"
                                           class="btn btn-primary btn-block w-100 mb-2">
                                            <i class="fa fa-plus me-1"/> Register for this Tournament
                                        </a>
                                    </t>
                                    <t t-if="tournament.state == 'draft'">
                                        <p class="text-muted small">Registration is not yet open.</p>
                                    </t>
                                    <t t-if="tournament.state in ('in_progress', 'closed')">
                                        <p class="text-muted small">Registration is closed.</p>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Participants -->
                    <div class="row mt-4" t-if="participants">
                        <div class="col-12">
                            <h3>Registered Participants</h3>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Team</th>
                                        <th>Club</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="participants" t-as="participant">
                                        <tr>
                                            <td><t t-esc="participant.seed or ''"/></td>
                                            <td><t t-esc="participant.team_id.name"/></td>
                                            <td><t t-esc="participant.club_id.name"/></td>
                                            <td>
                                                <span class="badge"
                                                      t-att-class="'bg-success' if participant.state == 'confirmed' else 'bg-warning' if participant.state == 'registered' else 'bg-secondary'">
                                                    <t t-esc="dict(participant._fields['state'].selection).get(participant.state)"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Tournament Registration Form (Public, requires login)         -->
    <!-- ============================================================ -->

    <template id="tournament_register_page" name="Tournament Registration">
        <t t-call="website.layout">
            <div id="wrap" class="oe_website_sale">
                <div class="container py-4">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/tournaments">Tournaments</a></li>
                            <li class="breadcrumb-item">
                                <a t-attf-href="/tournament/#{tournament.id}">
                                    <t t-esc="tournament.name"/>
                                </a>
                            </li>
                            <li class="breadcrumb-item active">Register</li>
                        </ol>
                    </nav>

                    <h1>Register for <t t-esc="tournament.name"/></h1>

                    <!-- Alerts -->
                    <div t-if="error" class="alert alert-danger">
                        <t t-esc="error"/>
                    </div>
                    <div t-if="success" class="alert alert-success">
                        <t t-esc="success"/>
                    </div>

                    <div class="mb-3" t-if="tournament.category or tournament.gender">
                        <span class="badge text-bg-light me-2" t-if="tournament.category">
                            Category: <t t-esc="dict(tournament._fields['category'].selection).get(tournament.category)"/>
                        </span>
                        <span class="badge text-bg-light" t-if="tournament.gender">
                            Gender: <t t-esc="dict(tournament._fields['gender'].selection).get(tournament.gender)"/>
                        </span>
                    </div>

                    <t t-if="teams">
                        <div class="card">
                            <div class="card-body">
                                <form t-attf-action="/tournament/#{tournament.id}/register"
                                      method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>

                                    <div class="mb-3">
                                        <label for="team_id" class="form-label">Select Team <span class="text-danger">*</span></label>
                                        <select name="team_id" id="team_id" class="form-select" required="1">
                                            <option value="">-- Select a team --</option>
                                            <t t-foreach="teams" t-as="team">
                                                <option t-att-value="team.id">
                                                    <t t-esc="team.name"/>
                                                    (<t t-esc="team.club_id.name"/>)
                                                </option>
                                            </t>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label for="notes" class="form-label">Notes (optional)</label>
                                        <textarea name="notes" id="notes" class="form-control" rows="3"
                                                  placeholder="Any additional information..."/>
                                    </div>

                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa fa-paper-plane me-1"/> Submit Registration
                                    </button>
                                    <a t-attf-href="/tournament/#{tournament.id}"
                                       class="btn btn-outline-secondary ms-2">Cancel</a>
                                </form>
                            </div>
                        </div>
                    </t>
                    <div t-elif="not error" class="alert alert-warning">
                        No eligible teams are currently available for this tournament.
                    </div>

                    <div class="card mt-3" t-if="excluded_teams">
                        <div class="card-body">
                            <h5 class="card-title">Unavailable Teams</h5>
                            <p class="text-muted small mb-3">
                                These teams are hidden from the registration dropdown because they are already registered or do not match this tournament's requirements.
                            </p>
                            <ul class="list-group list-group-flush">
                                <t t-foreach="excluded_teams" t-as="entry">
                                    <li class="list-group-item px-0">
                                        <div class="fw-semibold">
                                            <t t-esc="entry['name']"/>
                                            <span class="text-muted">(<t t-esc="entry['club']"/>)</span>
                                        </div>
                                        <div class="small text-muted">
                                            <t t-esc="entry['reason']"/>
                                        </div>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>