<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="tournament_list_page_public_coverage" inherit_id="sports_federation_portal.tournament_list_page" name="Tournament List Public Coverage">
        <xpath expr="//form[@action='/tournaments']" position="after">
            <section id="published" class="mb-5" t-if="featured_public_tournaments or archived_public_tournaments">
                <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
                    <div>
                        <h2 class="h3 mb-1">Published Tournament Coverage</h2>
                        <p class="text-muted mb-0">Schedules, standings, results, and bracket coverage now live inside the main Tournaments area.</p>
                    </div>
                    <a t-if="archived_public_tournaments" href="#published-archive" class="btn btn-outline-secondary btn-sm">
                        Past Published Tournaments
                    </a>
                </div>

                <div class="row" t-if="featured_public_tournaments">
                    <t t-foreach="featured_public_tournaments" t-as="featured_tournament">
                        <div class="col-lg-6 mb-4">
                            <div class="card h-100 border-primary-subtle shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                                        <div>
                                            <h3 class="h5 mb-1">
                                                <a t-att-href="featured_tournament.get_public_path()" class="text-decoration-none">
                                                    <t t-esc="featured_tournament.name"/>
                                                </a>
                                            </h3>
                                            <p class="text-muted small mb-0" t-if="featured_tournament.date_start">
                                                <t t-esc="featured_tournament.date_start" t-options='{"widget": "date"}'/>
                                                <t t-if="featured_tournament.date_end">
                                                    - <t t-esc="featured_tournament.date_end" t-options='{"widget": "date"}'/>
                                                </t>
                                            </p>
                                        </div>
                                        <span class="badge text-bg-primary">Published</span>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 mb-3 small text-muted">
                                        <span t-if="featured_tournament.get_public_schedule_sections()"><i class="fa fa-calendar me-1"/>Schedule</span>
                                        <span t-if="featured_tournament.show_public_results"><i class="fa fa-list me-1"/>Results</span>
                                        <span t-if="featured_tournament.show_public_standings"><i class="fa fa-table me-1"/>Standings</span>
                                        <span t-if="featured_tournament.has_public_bracket()"><i class="fa fa-sitemap me-1"/>Bracket</span>
                                    </div>

                                    <div t-if="featured_tournament.public_description"
                                         class="text-muted small mb-3"
                                         style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;"
                                         t-field="featured_tournament.public_description"/>

                                    <div class="d-flex flex-wrap gap-2">
                                        <a t-att-href="featured_tournament.get_public_path()" class="btn btn-outline-secondary btn-sm">Tournament Hub</a>
                                        <a t-att-href="featured_tournament.get_public_path()" class="btn btn-primary btn-sm">Public Coverage</a>
                                        <a t-if="featured_tournament.show_public_results" t-att-href="featured_tournament.get_public_results_path()" class="btn btn-outline-primary btn-sm">Results</a>
                                        <a t-if="featured_tournament.show_public_standings" t-att-href="featured_tournament.get_public_standings_path()" class="btn btn-outline-primary btn-sm">Standings</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <div id="published-archive" class="mt-2" t-if="archived_public_tournaments">
                    <h3 class="h5 mb-3">Past Published Tournaments</h3>
                    <div class="row">
                        <t t-foreach="archived_public_tournaments" t-as="archived_tournament">
                            <div class="col-md-4 mb-3">
                                <div class="card h-100 border-secondary-subtle">
                                    <div class="card-body">
                                        <h4 class="h6 mb-1">
                                            <a t-att-href="archived_tournament.get_public_path()" class="text-decoration-none">
                                                <t t-esc="archived_tournament.name"/>
                                            </a>
                                        </h4>
                                        <p class="text-muted small mb-3" t-if="archived_tournament.date_start">
                                            <t t-esc="archived_tournament.date_start" t-options='{"widget": "date"}'/>
                                            <t t-if="archived_tournament.date_end">
                                                - <t t-esc="archived_tournament.date_end" t-options='{"widget": "date"}'/>
                                            </t>
                                        </p>
                                        <a t-att-href="archived_tournament.get_public_path()" class="btn btn-outline-secondary btn-sm">View Coverage</a>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </section>
        </xpath>
    </template>

    <template id="tournament_detail_page_public_coverage" inherit_id="sports_federation_portal.tournament_detail_page" name="Tournament Detail Public Coverage">
        <xpath expr="//div[hasclass('card-body')][h5[normalize-space()='Actions']]" position="inside">
            <div class="mt-4" t-if="'website_published' in tournament._fields and tournament.website_published">
                <hr class="my-3"/>
                <h6 class="mb-2">Public Coverage</h6>
                <p class="text-muted small">This tournament is published on the website. Fans and media can use these public pages.</p>
                <div class="d-grid gap-2">
                    <a t-att-href="tournament.get_public_path()" class="btn btn-outline-secondary w-100">Public Overview</a>
                    <a t-if="tournament.get_public_schedule_sections()" t-att-href="tournament.get_public_schedule_path()" class="btn btn-outline-secondary w-100">Public Schedule</a>
                    <a t-if="tournament.show_public_results" t-att-href="tournament.get_public_results_path()" class="btn btn-outline-secondary w-100">Public Results</a>
                    <a t-if="tournament.show_public_standings" t-att-href="tournament.get_public_standings_path()" class="btn btn-outline-secondary w-100">Public Standings</a>
                    <a t-if="tournament.has_public_bracket()" t-att-href="tournament.get_public_bracket_path()" class="btn btn-outline-secondary w-100">Public Bracket</a>
                </div>
            </div>
        </xpath>
    </template>

</odoo>