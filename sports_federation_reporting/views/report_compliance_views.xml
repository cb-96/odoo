<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_federation_report_compliance_list" model="ir.ui.view">
        <field name="name">federation.report.compliance.list</field>
        <field name="model">federation.report.compliance</field>
        <field name="arch" type="xml">
            <list string="Compliance Report">
                <field name="target_model"/>
                <field name="compliant_count"/>
                <field name="missing_count"/>
                <field name="pending_count"/>
                <field name="expired_count"/>
                <field name="non_compliant_count"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_federation_report_compliance_pivot" model="ir.ui.view">
        <field name="name">federation.report.compliance.pivot</field>
        <field name="model">federation.report.compliance</field>
        <field name="arch" type="xml">
            <pivot string="Compliance Report">
                <field name="target_model" type="row"/>
                <field name="compliant_count" type="measure"/>
                <field name="missing_count" type="measure"/>
                <field name="pending_count" type="measure"/>
                <field name="expired_count" type="measure"/>
                <field name="non_compliant_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action -->
    <record id="action_federation_report_compliance" model="ir.actions.act_window">
        <field name="name">Compliance Report</field>
        <field name="res_model">federation.report.compliance</field>
        <field name="view_mode">list,pivot</field>
    </record>

</odoo>