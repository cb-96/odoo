<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_report_operational_search" model="ir.ui.view">
        <field name="name">federation.report.operational.search</field>
        <field name="model">federation.report.operational</field>
        <field name="arch" type="xml">
            <search string="Operational KPIs">
                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="readiness_status"/>
                <filter name="blocked" string="Blocked" domain="[('readiness_status', '=', 'blocked')]"/>
                <filter name="attention" string="Attention" domain="[('readiness_status', '=', 'attention')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_season" string="Season" context="{'group_by': 'season_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'readiness_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_federation_report_operational_list" model="ir.ui.view">
        <field name="name">federation.report.operational.list</field>
        <field name="model">federation.report.operational</field>
        <field name="arch" type="xml">
            <list string="Operational KPIs" create="0" edit="0" delete="0">
                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="tournament_state"/>
                <field name="participant_count"/>
                <field name="confirmed_participant_count"/>
                <field name="participant_confirmation_rate"/>
                <field name="match_count"/>
                <field name="completed_match_count"/>
                <field name="match_completion_rate"/>
                <field name="frozen_standing_count"/>
                <field name="standing_line_coverage"/>
                <field name="pending_finance_event_count"/>
                <field name="pending_finance_amount"/>
                <field name="open_club_compliance_count"/>
                <field name="readiness_status"/>
            </list>
        </field>
    </record>

    <record id="view_federation_report_operational_pivot" model="ir.ui.view">
        <field name="name">federation.report.operational.pivot</field>
        <field name="model">federation.report.operational</field>
        <field name="arch" type="xml">
            <pivot string="Operational KPIs">
                <field name="season_id" type="row"/>
                <field name="readiness_status" type="col"/>
                <field name="participant_count" type="measure"/>
                <field name="confirmed_participant_count" type="measure"/>
                <field name="match_count" type="measure"/>
                <field name="completed_match_count" type="measure"/>
                <field name="pending_finance_amount" type="measure"/>
                <field name="open_club_compliance_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_federation_report_operational" model="ir.actions.act_window">
        <field name="name">Operational KPIs</field>
        <field name="res_model">federation.report.operational</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="view_federation_report_operational_search"/>
    </record>

    <record id="view_federation_report_standing_reconciliation_search" model="ir.ui.view">
        <field name="name">federation.report.standing.reconciliation.search</field>
        <field name="model">federation.report.standing.reconciliation</field>
        <field name="arch" type="xml">
            <search string="Standings Reconciliation">
                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="reconciliation_status"/>
                <filter name="blocked" string="Blocked" domain="[('reconciliation_status', '=', 'blocked')]"/>
                <filter name="attention" string="Attention" domain="[('reconciliation_status', '=', 'attention')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_season" string="Season" context="{'group_by': 'season_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'reconciliation_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_federation_report_standing_reconciliation_list" model="ir.ui.view">
        <field name="name">federation.report.standing.reconciliation.list</field>
        <field name="model">federation.report.standing.reconciliation</field>
        <field name="arch" type="xml">
            <list string="Standings Reconciliation" create="0" edit="0" delete="0">
                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="tournament_state"/>
                <field name="confirmed_participant_count"/>
                <field name="covered_participant_count"/>
                <field name="frozen_standing_count"/>
                <field name="missing_participant_count"/>
                <field name="orphaned_participant_count"/>
                <field name="reconciliation_status"/>
                <field name="reconciliation_note"/>
            </list>
        </field>
    </record>

    <record id="view_federation_report_standing_reconciliation_pivot" model="ir.ui.view">
        <field name="name">federation.report.standing.reconciliation.pivot</field>
        <field name="model">federation.report.standing.reconciliation</field>
        <field name="arch" type="xml">
            <pivot string="Standings Reconciliation">
                <field name="season_id" type="row"/>
                <field name="reconciliation_status" type="col"/>
                <field name="confirmed_participant_count" type="measure"/>
                <field name="covered_participant_count" type="measure"/>
                <field name="missing_participant_count" type="measure"/>
                <field name="orphaned_participant_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_federation_report_standing_reconciliation" model="ir.actions.act_window">
        <field name="name">Standings Reconciliation</field>
        <field name="res_model">federation.report.standing.reconciliation</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="view_federation_report_standing_reconciliation_search"/>
    </record>

    <record id="view_federation_report_finance_reconciliation_search" model="ir.ui.view">
        <field name="name">federation.report.finance.reconciliation.search</field>
        <field name="model">federation.report.finance.reconciliation</field>
        <field name="arch" type="xml">
            <search string="Finance Reconciliation">
                <field name="fee_type_id"/>
                <field name="follow_up_status"/>
                <field name="counterparty_display"/>
                <filter name="needs_follow_up" string="Needs Follow-up" domain="[('needs_follow_up', '=', True)]"/>
                <filter name="awaiting_reference" string="Awaiting Reference" domain="[('follow_up_status', '=', 'awaiting_reference')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_fee_type" string="Fee Type" context="{'group_by': 'fee_type_id'}"/>
                    <filter name="group_follow_up" string="Follow-up Status" context="{'group_by': 'follow_up_status'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_federation_report_finance_reconciliation_list" model="ir.ui.view">
        <field name="name">federation.report.finance.reconciliation.list</field>
        <field name="model">federation.report.finance.reconciliation</field>
        <field name="arch" type="xml">
            <list string="Finance Reconciliation" create="0" edit="0" delete="0">
                <field name="finance_event_id"/>
                <field name="fee_type_id"/>
                <field name="state"/>
                <field name="follow_up_status"/>
                <field name="counterparty_display"/>
                <field name="source_model"/>
                <field name="source_res_id"/>
                <field name="amount"/>
                <field name="external_ref"/>
                <field name="invoice_ref"/>
                <field name="age_days"/>
                <field name="needs_follow_up"/>
            </list>
        </field>
    </record>

    <record id="view_federation_report_finance_reconciliation_pivot" model="ir.ui.view">
        <field name="name">federation.report.finance.reconciliation.pivot</field>
        <field name="model">federation.report.finance.reconciliation</field>
        <field name="arch" type="xml">
            <pivot string="Finance Reconciliation">
                <field name="fee_type_id" type="row"/>
                <field name="follow_up_status" type="row"/>
                <field name="amount" type="measure"/>
                <field name="age_days" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_federation_report_finance_reconciliation" model="ir.actions.act_window">
        <field name="name">Finance Reconciliation</field>
        <field name="res_model">federation.report.finance.reconciliation</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="view_federation_report_finance_reconciliation_search"/>
        <field name="context">{'search_default_needs_follow_up': 1}</field>
    </record>

</odoo>