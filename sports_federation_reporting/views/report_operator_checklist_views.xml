<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_report_operator_checklist_search" model="ir.ui.view">
        <field name="name">federation.report.operator.checklist.search</field>
        <field name="model">federation.report.operator.checklist</field>
        <field name="arch" type="xml">
            <search string="Operator Checklist">
                <field name="queue_name"/>
                <field name="status"/>
                <field name="owner_display"/>
                <filter name="needs_attention" string="Needs Attention" domain="[('open_count', '&gt;', 0)]"/>
                <filter name="blocked" string="Blocked" domain="[('status', '=', 'blocked')]"/>
                <filter name="attention" string="Attention" domain="[('status', '=', 'attention')]"/>
                <group>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_owner" string="Owner" context="{'group_by': 'owner_display'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_federation_report_operator_checklist_list" model="ir.ui.view">
        <field name="name">federation.report.operator.checklist.list</field>
        <field name="model">federation.report.operator.checklist</field>
        <field name="arch" type="xml">
            <list string="Operator Checklist" create="0" edit="0" delete="0">
                <field name="queue_name"/>
                <field name="owner_display"/>
                <field name="open_count"/>
                <field name="escalated_count"/>
                <field name="oldest_age_days"/>
                <field name="status"/>
                <field name="summary"/>
                <button name="action_open_queue" type="object" string="Open Queue"/>
            </list>
        </field>
    </record>

    <record id="action_federation_report_operator_checklist" model="ir.actions.act_window">
        <field name="name">Operator Checklist</field>
        <field name="res_model">federation.report.operator.checklist</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_federation_report_operator_checklist_search"/>
        <field name="context">{'search_default_needs_attention': 1}</field>
    </record>

</odoo>