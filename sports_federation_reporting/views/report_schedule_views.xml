<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_report_schedule_search" model="ir.ui.view">
        <field name="name">federation.report.schedule.search</field>
        <field name="model">federation.report.schedule</field>
        <field name="arch" type="xml">
            <search string="Report Schedules">
                <field name="name"/>
                <field name="report_type"/>
                <field name="period_type"/>
                <field name="season_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="failed" string="Last Run Failed" domain="[('last_run_status', '=', 'failed')]"/>
            </search>
        </field>
    </record>

    <record id="view_federation_report_schedule_list" model="ir.ui.view">
        <field name="name">federation.report.schedule.list</field>
        <field name="model">federation.report.schedule</field>
        <field name="arch" type="xml">
            <list string="Report Schedules">
                <field name="name"/>
                <field name="report_type"/>
                <field name="period_type"/>
                <field name="season_id"/>
                <field name="next_run_on"/>
                <field name="last_attempt_on"/>
                <field name="last_run_on"/>
                <field name="last_run_status"/>
                <field name="last_failure_on" optional="show"/>
                <field name="consecutive_failure_count" optional="show"/>
                <field name="last_row_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_federation_report_schedule_form" model="ir.ui.view">
        <field name="name">federation.report.schedule.form</field>
        <field name="model">federation.report.schedule</field>
        <field name="arch" type="xml">
            <form string="Report Schedule">
                <header>
                    <button name="action_generate_now" string="Generate Now" type="object" class="btn-primary"/>
                    <button name="action_open_report" string="Open Report" type="object"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="report_type"/>
                            <field name="period_type"/>
                            <field name="season_id" invisible="report_type in ('finance_reconciliation', 'compliance_summary', 'compliance_remediation', 'board_pack', 'audit_pack')"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="next_run_on"/>
                            <field name="last_attempt_on" readonly="1"/>
                            <field name="last_run_on" readonly="1"/>
                            <field name="last_run_status" readonly="1"/>
                            <field name="last_failure_on" readonly="1"/>
                            <field name="consecutive_failure_count" readonly="1"/>
                            <field name="last_period_start" readonly="1"/>
                            <field name="last_period_end" readonly="1"/>
                            <field name="last_row_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="generated_filename" readonly="1"/>
                        <field name="generated_file" filename="generated_filename" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes" placeholder="Operational notes for this schedule."/>
                    </group>
                    <group invisible="not last_error_message">
                        <field name="last_error_message" readonly="1" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_federation_report_schedule" model="ir.actions.act_window">
        <field name="name">Report Schedules</field>
        <field name="res_model">federation.report.schedule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_report_schedule_search"/>
    </record>

</odoo>