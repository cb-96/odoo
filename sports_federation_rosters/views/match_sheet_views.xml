<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_federation_match_sheet_list" model="ir.ui.view">
        <field name="name">federation.match.sheet.list</field>
        <field name="model">federation.match.sheet</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="match_id"/>
                <field name="team_id"/>
                <field name="side"/>
                <field name="state"/>
                <field name="line_count"/>
            </list>
        </field>
    </record>

    <record id="view_federation_match_sheet_form" model="ir.ui.view">
        <field name="name">federation.match.sheet.form</field>
        <field name="model">federation.match.sheet</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button name="action_lock" string="Lock" type="object" invisible="state != 'approved'" confirm="Locking this match sheet is irreversible. No further changes will be possible. Continue?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,locked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="match_id"/>
                            <field name="team_id"/>
                            <field name="roster_id"/>
                            <field name="side"/>
                        </group>
                        <group>
                            <field name="coach_name"/>
                            <field name="manager_name"/>
                            <field name="line_count"/>
                            <field name="substitution_count" readonly="1"/>
                            <field name="locked_on" readonly="1"/>
                            <field name="locked_by_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="ready_for_submission" readonly="1"/>
                        <field name="readiness_feedback" readonly="1" invisible="not readiness_feedback"/>
                    </group>
                    <notebook>
                        <page string="Sheet Lines" name="sheet_lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="player_id"/>
                                    <field name="roster_line_id"/>
                                    <field name="is_starter"/>
                                    <field name="is_substitute"/>
                                    <field name="is_captain"/>
                                    <field name="jersey_number"/>
                                    <field name="entered_minute"/>
                                    <field name="left_minute"/>
                                    <field name="eligible" readonly="1"/>
                                    <field name="eligibility_feedback" readonly="1" optional="hide"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Audit History" name="audit_history">
                            <field name="audit_event_ids" readonly="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="event_on"/>
                                    <field name="event_type"/>
                                    <field name="player_id" optional="hide"/>
                                    <field name="author_id"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_federation_match_sheet" model="ir.actions.act_window">
        <field name="name">Match Sheets</field>
        <field name="res_model">federation.match.sheet</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>