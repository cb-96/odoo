<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_federation_team_roster_list" model="ir.ui.view">
        <field name="name">federation.team.roster.list</field>
        <field name="model">federation.team.roster</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="team_id"/>
                <field name="season_id"/>
                <field name="competition_id"/>
                <field name="rule_set_id"/>
                <field name="status"/>
                <field name="valid_from"/>
                <field name="valid_to"/>
                <field name="line_count"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_federation_team_roster_form" model="ir.ui.view">
        <field name="name">federation.team.roster.form</field>
        <field name="model">federation.team.roster</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_draft" string="Set to Draft" type="object" class="oe_highlight" invisible="status != 'active'"/>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                    <button name="action_close" string="Close" type="object" invisible="status != 'active'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_lines" type="object" class="oe_stat_button" icon="fa-users" invisible="not line_count">
                            <field name="line_count" string="Players" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="team_id"/>
                            <field name="season_id"/>
                            <field name="competition_id"/>
                            <field name="season_registration_id"/>
                        </group>
                        <group>
                            <field name="rule_set_id"/>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                            <field name="min_players_required"/>
                            <field name="max_players_allowed"/>
                            <field name="club_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Roster Lines" name="roster_lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="player_id"/>
                                    <field name="status"/>
                                    <field name="jersey_number"/>
                                    <field name="is_captain"/>
                                    <field name="is_vice_captain"/>
                                    <field name="license_id"/>
                                    <field name="eligible" readonly="1"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_federation_team_roster" model="ir.actions.act_window">
        <field name="name">Team Rosters</field>
        <field name="res_model">federation.team.roster</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>