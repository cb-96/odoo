<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_rule_set_form" model="ir.ui.view">
        <field name="name">federation.rule.set.form</field>
        <field name="model">federation.rule.set</field>
        <field name="arch" type="xml">
            <form string="Rule Set">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(federation_competition_action)d" type="action"
                                class="oe_stat_button" icon="fa-trophy"
                                context="{'search_default_rule_set_id': active_id}">
                            <field name="competition_count" widget="statinfo" string="Competitions"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active = True"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Rule Set Name"/>
                        </h1>
                        <h3>
                            <field name="code" placeholder="Code"/>
                        </h3>
                    </div>
                    <group>
                        <group string="General">
                            <field name="competition_id"/>
                            <field name="seeding_mode"/>
                        </group>
                        <group string="Default Points">
                            <field name="points_win"/>
                            <field name="points_draw"/>
                            <field name="points_loss"/>
                        </group>
                        <group string="Squad Limits">
                            <field name="squad_min_size"/>
                            <field name="squad_max_size"/>
                        </group>
                        <group string="Officiating">
                            <field name="referee_required_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Points Rules" name="points_rules">
                            <field name="points_rule_ids">
                                <list editable="bottom">
                                    <field name="result_type"/>
                                    <field name="points"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tie-Break Rules" name="tie_break_rules">
                            <field name="tie_break_rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="tie_break_type"/>
                                    <field name="description"/>
                                    <field name="reverse_order"/>
                                </list>
                            </field>
                        </page>
                        <page string="Eligibility Rules" name="eligibility_rules">
                            <field name="eligibility_rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="eligibility_type"/>
                                    <field name="is_placeholder"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Qualification Rules" name="qualification_rules">
                            <field name="qualification_rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="qualification_type"/>
                                    <field name="value_integer"/>
                                    <field name="value_percent"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_federation_rule_set_list" model="ir.ui.view">
        <field name="name">federation.rule.set.list</field>
        <field name="model">federation.rule.set</field>
        <field name="arch" type="xml">
            <list string="Rule Sets">
                <field name="name"/>
                <field name="code"/>
                <field name="competition_id"/>
                <field name="points_win"/>
                <field name="points_draw"/>
                <field name="points_loss"/>
                <field name="seeding_mode"/>
            </list>
        </field>
    </record>

    <record id="view_federation_rule_set_search" model="ir.ui.view">
        <field name="name">federation.rule.set.search</field>
        <field name="model">federation.rule.set</field>
        <field name="arch" type="xml">
            <search string="Search Rule Sets">
                <field name="name"/>
                <field name="code"/>
                <field name="competition_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="competition" string="Competition" context="{'group_by': 'competition_id'}"/>
                    <filter name="seeding" string="Seeding Mode" context="{'group_by': 'seeding_mode'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_rule_set_action" model="ir.actions.act_window">
        <field name="name">Rule Sets</field>
        <field name="res_model">federation.rule.set</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_rule_set_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first rule set.
            </p>
        </field>
    </record>

</odoo>