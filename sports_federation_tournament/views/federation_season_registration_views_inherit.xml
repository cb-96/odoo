<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit the form view to add competition and rule set fields -->
    <record id="view_federation_season_registration_form_inherit" model="ir.ui.view">
        <field name="name">federation.season.registration.form.inherit</field>
        <field name="model">federation.season.registration</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_season_registration_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[field[@name='division']]" position="inside">
                <field name="competition_id"/>
                <field name="rule_set_id"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit the tree view to add the fields -->
    <record id="view_federation_season_registration_tree_inherit" model="ir.ui.view">
        <field name="name">federation.season.registration.tree.inherit</field>
        <field name="model">federation.season.registration</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_season_registration_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='division']" position="after">
                <field name="competition_id" optional="hide"/>
                <field name="rule_set_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit the search view to add the fields -->
    <record id="view_federation_season_registration_search_inherit" model="ir.ui.view">
        <field name="name">federation.season.registration.search.inherit</field>
        <field name="model">federation.season.registration</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_season_registration_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='team_id']" position="after">
                <field name="competition_id"/>
                <field name="rule_set_id"/>
            </xpath>
        </field>
    </record>

</odoo>