<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_tournament_form" model="ir.ui.view">
        <field name="name">federation.tournament.form</field>
        <field name="model">federation.tournament</field>
        <field name="arch" type="xml">
            <form string="Tournament">
                <header>
                    <button name="action_open" string="Open" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start" string="Start" type="object" class="btn-primary"
                            invisible="state != 'open'"/>
                    <button name="action_close" string="Close" type="object" class="btn-secondary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,in_progress,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(federation_tournament_stage_action)d" type="action"
                                class="oe_stat_button" icon="fa-sitemap"
                                context="{'search_default_tournament_id': id}">
                            <field name="stage_count" widget="statinfo" string="Stages"/>
                        </button>
                        <button name="%(federation_tournament_participant_action)d" type="action"
                                class="oe_stat_button" icon="fa-users"
                                context="{'search_default_tournament_id': id}">
                            <field name="participant_count" widget="statinfo" string="Participants"/>
                        </button>
                        <button name="%(federation_match_action)d" type="action"
                                class="oe_stat_button" icon="fa-list"
                                context="{'search_default_tournament_id': id}">
                            <field name="match_count" widget="statinfo" string="Matches"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Tournament Name"/>
                        </h1>
                        <h3>
                            <field name="code" placeholder="Code"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Schedule">
                            <field name="tournament_type"/>
                            <field name="date_start"/>
                            <field name="date_end" invisible="tournament_type == 'single_day'"/>
                        </group>
                        <group string="Details">
                            <field name="season_id"/>
                            <field name="location"/>
                            <field name="max_participants"/>
                            <field name="competition_id"/>
                            <field name="rule_set_id"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_federation_tournament_list" model="ir.ui.view">
        <field name="name">federation.tournament.list</field>
        <field name="model">federation.tournament</field>
        <field name="arch" type="xml">
            <list string="Tournaments">
                <field name="name"/>
                <field name="code"/>
                <field name="season_id"/>
                <field name="date_start"/>
                <field name="tournament_type"/>
                <field name="state"/>
                <field name="participant_count"/>
            </list>
        </field>
    </record>

    <record id="view_federation_tournament_search" model="ir.ui.view">
        <field name="name">federation.tournament.search</field>
        <field name="model">federation.tournament</field>
        <field name="arch" type="xml">
            <search string="Search Tournaments">
                <field name="name"/>
                <field name="code"/>
                <field name="season_id"/>
                <field name="location"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="open" string="Open" domain="[('state', '=', 'open')]"/>
                <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <group>
                    <filter name="season" string="Season" context="{'group_by': 'season_id'}"/>
                    <filter name="type" string="Type" context="{'group_by': 'tournament_type'}"/>
                    <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_tournament_action" model="ir.actions.act_window">
        <field name="name">Tournaments</field>
        <field name="res_model">federation.tournament</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_tournament_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tournament.
            </p>
        </field>
    </record>

</odoo>