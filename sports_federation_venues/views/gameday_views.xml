<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_gameday_form" model="ir.ui.view">
        <field name="name">federation.gameday.form</field>
        <field name="model">federation.gameday</field>
        <field name="arch" type="xml">
            <form string="Gameday">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="tournament_id"/>
                        <field name="sequence"/>
                        <field name="stage_id"/>
                        <field name="start_datetime"/>
                        <field name="venue_id"/>
                        <field name="playing_area_id"/>
                        <field name="match_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Matches">
                            <field name="match_ids">
                                <list>
                                    <field name="stage_id" optional="hide"/>
                                    <field name="date_scheduled"/>
                                    <field name="home_team_id"/>
                                    <field name="away_team_id"/>
                                    <field name="venue_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_federation_gameday_tree" model="ir.ui.view">
        <field name="name">federation.gameday.tree</field>
        <field name="model">federation.gameday</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tournament_id"/>
                <field name="stage_id"/>
                <field name="sequence"/>
                <field name="start_datetime"/>
                <field name="venue_id"/>
                <field name="match_count"/>
            </list>
        </field>
    </record>

    <record id="view_federation_gameday_search" model="ir.ui.view">
        <field name="name">federation.gameday.search</field>
        <field name="model">federation.gameday</field>
        <field name="arch" type="xml">
            <search string="Search Gamedays">
                <field name="name"/>
                <field name="tournament_id"/>
                <field name="stage_id"/>
                <field name="venue_id"/>
                <filter name="planned" string="Planned" domain="[('venue_id', '=', False)]"/>
                <filter name="scheduled" string="Scheduled" domain="[('venue_id', '!=', False)]"/>
                <group>
                    <filter name="group_tournament" string="Tournament" context="{'group_by': 'tournament_id'}"/>
                    <filter name="group_stage" string="Stage" context="{'group_by': 'stage_id'}"/>
                    <filter name="group_venue" string="Venue" context="{'group_by': 'venue_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_federation_gameday" model="ir.actions.act_window">
        <field name="name">Gamedays</field>
        <field name="res_model">federation.gameday</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_gameday_search"/>
    </record>

</odoo>
