<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_match_form_inherit_venue" model="ir.ui.view">
        <field name="name">federation.match.form.inherit.venue</field>
        <field name="model">federation.match</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_match_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_scheduled']" position="after">
                <field name="venue_id"/>
                <field name="playing_area_id" domain="[('venue_id', '=', venue_id)]"/>
            </xpath>
        </field>
    </record>

    <record id="view_federation_match_tree_inherit_venue" model="ir.ui.view">
        <field name="name">federation.match.tree.inherit.venue</field>
        <field name="model">federation.match</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_match_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='away_score']" position="after">
                <field name="venue_id"/>
                <field name="playing_area_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_federation_match_search_inherit_venue" model="ir.ui.view">
        <field name="name">federation.match.search.inherit.venue</field>
        <field name="model">federation.match</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_match_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='away_team_id']" position="after">
                <field name="venue_id"/>
                <field name="playing_area_id"/>
            </xpath>
            <xpath expr="//filter[@name='state']" position="after">
                <filter name="venue" string="Venue" context="{'group_by': 'venue_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>