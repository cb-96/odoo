<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_tournament_round_form_inherit_venue" model="ir.ui.view">
        <field name="name">federation.tournament.round.form.inherit.venue</field>
        <field name="model">federation.tournament.round</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_tournament_round_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='round_date']" position="after">
                <field name="venue_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_federation_tournament_round_tree_inherit_venue" model="ir.ui.view">
        <field name="name">federation.tournament.round.tree.inherit.venue</field>
        <field name="model">federation.tournament.round</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_tournament_round_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='round_date']" position="after">
                <field name="venue_id" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>